# ===========================================
# Spacebot Environment Variables
# ===========================================
# Copy this to .env and fill in your values

# ---- Bifrost AI Gateway ----
# Your publicly accessible Bifrost instance
BIFROST_URL=https://bifrost.yourdomain.com
BIFROST_VIRTUAL_KEY=your-bifrost-virtual-key-here

# ---- Channel Tokens (enable what you need) ----
# Discord bot token (for Discord channel integration)
# DISCORD_BOT_TOKEN=

# Slack bot token (for Slack channel integration)
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# Telegram bot token (for Telegram channel integration)
# TELEGRAM_BOT_TOKEN=

# ---- Brave Search (optional — for web search in workers) ----
# BRAVE_SEARCH_API_KEY=

# ---- OpenCode (optional — for AI coding agent workers) ----
# OPENCODE_ZEN_API_KEY=
# OPENCODE_GO_KEY=
